# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/campusvault"

# Firebase Admin Credentials (required by auth middleware)
# Use only one of the following options:
# 1) Path to service account file (recommended for local development)
FIREBASE_ADMIN_SDK_PATH=./firebase-admin-sdk.json
# 2) Inline JSON string (recommended for CI/hosting)
# FIREBASE_ADMIN_SDK_JSON={"type":"service_account",...}

# CORS Configuration (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
