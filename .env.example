# ============================================
# CLIENT ENVIRONMENT VARIABLES
# ============================================

# Firebase Configuration
# Get these values from your Firebase Console (https://console.firebase.google.com)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api

# ============================================
# SERVER ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# PostgreSQL Connection String
DATABASE_URL=postgresql://user:password@localhost:5432/campusvault

# Firebase Admin Configuration
# Download the service account JSON from Firebase Console (Project Settings > Service Accounts)
# Set this to the path of your service account JSON file or paste the JSON object
FIREBASE_ADMIN_SDK_PATH=./firebase-admin-sdk.json

# Optional: Instead of file path, you can set the JSON directly (for cloud deployments)
# FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# LLM API Configuration
# For OpenAI API (used for AI-powered features)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Alternative: For other LLM providers
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# HUGGING_FACE_API_KEY=your_hugging_face_api_key_here

# ============================================
# OPTIONAL ENVIRONMENT VARIABLES
# ============================================

# Logging Configuration
LOG_LEVEL=info

# JWT Secret for token generation (if using JWT authentication)
JWT_SECRET=your_jwt_secret_key_here_generate_a_strong_random_string

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@campusvault.com

# AWS S3 Configuration (optional, for file uploads)
AWS_S3_BUCKET=campusvault-uploads
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# ============================================
# DEVELOPMENT-SPECIFIC VARIABLES
# ============================================

# Enable debug mode
DEBUG=false

# Database Logging
DATABASE_LOG=false

# API Response Mock Mode (for testing without LLM calls)
USE_MOCK_RESPONSES=false